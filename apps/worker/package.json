{
  "name": "@rugkiller/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rugkiller/analysis": "workspace:*",
    "@rugkiller/chain": "workspace:*",
    "@rugkiller/db": "workspace:*",
    "@rugkiller/shared": "workspace:*",
    "bullmq": "^4.17.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
