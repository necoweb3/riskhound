    "@fastify/rate-limit": "^10.2.2",
    "@rugkiller/analysis": "workspace:*",
    "@rugkiller/chain": "workspace:*",
    "@rugkiller/db": "workspace:*",
    "@rugkiller/shared": "workspace:*",
    "bullmq": "^4.17.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "viem": "^2.23.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
