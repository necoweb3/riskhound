# ─── Database ───────────────────────────────────────────────
# Local default: SQLite (no Docker required)
DATABASE_URL=file:./dev.db
# Production / Docker Postgres:
# DATABASE_URL=postgresql://rugkiller:rugkiller@localhost:5432/rugkiller?schema=public

REDIS_URL=redis://localhost:6379
# When true (default for local), API/worker start without Redis
REDIS_OPTIONAL=true

# ─── Arc Testnet (analysis) ─────────────────────────────────
ARC_RPC_URL=https://rpc.drpc.testnet.arc.network
ARC_WS_URL=wss://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_API=https://testnet.arcscan.app/api
ARC_EXPLORER_V2=https://testnet.arcscan.app/api/v2
ARC_EXPLORER_URL=https://testnet.arcscan.app

# ─── Robinhood Chain (cross-chain intel) ────────────────────
ROBINHOOD_RPC_URL=
ROBINHOOD_CHAIN_ID=4663
ROBINHOOD_EXPLORER_API=https://robinhoodchain.blockscout.com/api
ROBINHOOD_EXPLORER_V2=https://robinhoodchain.blockscout.com/api/v2
ROBINHOOD_EXPLORER_URL=https://robinhoodchain.blockscout.com

# ─── x402 payments (Base; independent of analysis) ──────────
PAYMENT_NETWORK=base
PAYMENT_CHAIN_ID=8453
PAYMENT_RPC_URL=https://mainnet.base.org
PAYMENT_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Set your USDC receive wallet before enabling paid prod traffic
PAYMENT_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000
X402_FACILITATOR_URL=https://gateway-api.circle.com
X402_ENABLED=true

FREE_ANALYSES_PER_DAY=10
FREE_API_REQUESTS_PER_MINUTE=30
PRICE_BUY_SELL_SIM=0.10
PRICE_FUNDING_GRAPH=0.20
PRICE_FULL_REPORT=0.50

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_PUBLIC_URL=http://localhost:4000
BRIDGE_INDEXER_API_URL=http://localhost:4000
BRIDGE_INDEXER_POLL_MS=60000
OBSERVED_MAINNET_INDEXER_POLL_MS=300000
BRIDGE_SETTLEMENT_POLL_MS=60000
SOLANA_CCTP_POLL_MS=120000
EVM_CCTP_BACKFILL_POLL_MS=60000
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Comma-separated admin wallet addresses (empty = open admin in development only)
ADMIN_WALLETS=
JWT_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=168

ARC_INDEXER_POLL_MS=60000
ROBINHOOD_INDEXER_POLL_MS=120000
ANALYSIS_CONCURRENCY=2
RISK_MODEL_VERSION=1.0.0
