{
  "name": "@rugkiller/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "scripts": {
    "generate": "prisma generate",
    "generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "push:postgres": "prisma db push --schema prisma/postgres/schema.prisma --skip-generate",
    "migrate": "prisma migrate dev",
    "push": "node ../../scripts/db-push.mjs",
    "studio": "prisma studio",
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "prisma": "^6.3.1",
    "typescript": "^5.7.3"
  }
}
